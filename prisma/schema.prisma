generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(uuid())
  name  String
  tasks Task[]
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])
}
